@{
    ViewBag.Title = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CommunityHub Events! - Login</title>
    <link rel="stylesheet" href="~/Content/auth-styles.css">
    <link rel="stylesheet" href="~/Content/auth-split.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="auth-wrapper">

        <!-- LEFT: Form Side -->
        <div class="auth-form-side">
            <div class="auth-card">

                <div class="brand-logo">
                    <i class="bi bi-calendar-event"></i>
                    <h2>CommunityHub Events!</h2>
                    <p>Connect. Discover. Celebrate.</p>
                </div>

                <div class="alert-message" id="alertMessage"></div>

                <!-- ✅ Keep original form — connected to backend -->
                <form id="forgotPasswordForm">
                    <div class="form-group">
                        <label><i class="bi bi-person-badge"></i> Username</label>
                        <div class="input-wrapper">
                            <i class="bi bi-person-badge input-icon"></i>
                            <input type="text" class="form-control" id="username" name="username"
                                   placeholder="Enter your username" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label><i class="bi bi-envelope"></i> Email</label>
                        <div class="input-wrapper">
                            <i class="bi bi-envelope input-icon"></i>
                            <input type="email" class="form-control" id="email" name="email"
                                   placeholder="Enter your email" required>
                        </div>
                    </div>
                    <button type="submit" class="btn-primary-custom" id="submitBtn">
                        <i class="bi bi-send me-2"></i> Send Reset Request
                    </button>
                    <div class="form-footer mt-3">
                        Remember your password?
                        <a href="@Url.Action("Login", "Account")" class="form-link">Login</a>
                    </div>
                </form>

                <div class="back-home">
                    <a href="@Url.Action("LandingPage", "Home")">
                        <i class="bi bi-arrow-left"></i> Back to Home
                    </a>
                </div>

            </div>
        </div>

        <!-- RIGHT: Image Side -->
        <div class="auth-image-side-login">
            <div class="auth-image-overlay">
                <div class="auth-image-content">
                    <h2>Discover Amazing Events from your Community</h2>
                    <p>Join thousands of people connecting and celebrating together in your community.</p>
                    <div class="auth-image-stats">
                        <div class="stat">
                            <span class="stat-number">500+</span>
                            <span class="stat-label">Events</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">10k+</span>
                            <span class="stat-label">Members</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">50+</span>
                            <span class="stat-label">Cities</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Content/AccountAuth_Ajax.js"></script>
</body>
</html>

