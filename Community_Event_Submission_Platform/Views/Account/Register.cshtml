@{
    ViewBag.Title = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CommunityHub Events! - Register</title>
    <link rel="stylesheet" href="~/Content/auth-styles.css">
    <link rel="stylesheet" href="~/Content/auth-split.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="auth-wrapper">

        <!-- LEFT: Form Side -->
        <div class="auth-form-side">
            <div class="auth-card">

                <div class="brand-logo">
                    <i class="bi bi-calendar-event"></i>
                    <h2>CommunityHub Events!</h2>
                    <p>Connect. Discover. Celebrate.</p>
                </div>

                <div class="alert-message" id="alertMessage"></div>

                <!-- ✅ Keep original form — connected to backend -->
                <form id="registerForm">
                    <div class="form-group">
                        <label><i class="bi bi-person-badge"></i> Username</label>
                        <div class="input-wrapper">
                            <i class="bi bi-person-badge input-icon"></i>
                            <input type="text" class="form-control" name="username" placeholder="Choose a username" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label><i class="bi bi-person"></i> First Name</label>
                            <div class="input-wrapper">
                                <i class="bi bi-person input-icon"></i>
                                <input type="text" class="form-control" name="firstname" placeholder="Enter first name" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label><i class="bi bi-person"></i> Last Name</label>
                            <div class="input-wrapper">
                                <i class="bi bi-person input-icon"></i>
                                <input type="text" class="form-control" name="lastname" placeholder="Enter last name" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label><i class="bi bi-envelope"></i> Email Address</label>
                        <div class="input-wrapper">
                            <i class="bi bi-envelope input-icon"></i>
                            <input type="email" class="form-control" name="email" placeholder="Enter your email" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label><i class="bi bi-geo-alt"></i> Address</label>
                        <div class="input-wrapper">
                            <i class="bi bi-geo-alt input-icon"></i>
                            <input type="text" class="form-control" name="address" placeholder="Enter your address" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label><i class="bi bi-lock"></i> Password</label>
                            <div class="input-wrapper">
                                <i class="bi bi-lock input-icon"></i>
                                <input type="password" class="form-control" id="registerPassword" name="password" placeholder="Create a password" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label><i class="bi bi-lock-fill"></i> Confirm Password</label>
                            <div class="input-wrapper">
                                <i class="bi bi-lock-fill input-icon"></i>
                                <input type="password" class="form-control" id="confirmPassword" placeholder="Confirm password" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-check">
                        <input type="checkbox" id="terms" required>
                        <label for="terms">I agree to the <a href="#" class="form-link">Terms & Conditions</a></label>
                    </div>

                    <button type="submit" class="btn-primary-custom">
                        <i class="bi bi-person-plus me-2"></i> Create Account
                    </button>

                    <div class="divider">
                        <span>or sign up with</span>
                    </div>

                    <div class="social-login">
                        <button type="button" class="social-btn" title="Sign up with Google">
                            <i class="bi bi-google"></i>
                        </button>
                        <button type="button" class="social-btn" title="Sign up with Facebook">
                            <i class="bi bi-facebook"></i>
                        </button>
                        <button type="button" class="social-btn" title="Sign up with Apple">
                            <i class="bi bi-apple"></i>
                        </button>
                    </div>

                    <div class="form-footer">
                        Already have an account? <a href="@Url.Action("Login", "Account")" class="form-link">Login</a>
                    </div>
                </form>

                <div class="back-home">
                    <a href="@Url.Action("LandingPage", "Home")">
                        <i class="bi bi-arrow-left"></i> Back to Home
                    </a>
                </div>

            </div>
        </div>

        <!-- RIGHT: Image Side -->
        <div class="auth-image-side-register">
            <div class="auth-image-overlay">
                <div class="auth-image-content">
                    <h2>Discover Amazing Events</h2>
                    <p>Join thousands of people connecting and celebrating together in your community.</p>
                    <div class="auth-image-stats">
                        <div class="stat">
                            <span class="stat-number">500+</span>
                            <span class="stat-label">Events</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">10k+</span>
                            <span class="stat-label">Members</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">50+</span>
                            <span class="stat-label">Cities</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Content/AccountAuth_Ajax.js"></script>
</body>
</html>




