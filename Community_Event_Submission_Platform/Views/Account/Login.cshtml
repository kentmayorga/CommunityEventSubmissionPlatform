@{
    ViewBag.Title = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CommunityHub Events! - Login</title>
    <link rel="stylesheet" href="~/Content/UserInterface/auth-styles.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="auth-wrapper">

        <!-- LEFT: Form Side -->
        <div class="auth-form-side">
            <div class="auth-card">

                <div class="brand-logo">
                    <i class="bi bi-calendar-event"></i>
                    <h2>CommunityHub Events!</h2>
                    <p>Connect. Discover. Celebrate.</p>
                </div>

                <div class="alert-message" id="alertMessage"></div>

                <!-- ✅ Keep original form — connected to backend -->
                <form id="loginForm">
                    <div class="form-group">
                        <label><i class="bi bi-person-circle"></i> Username or Email</label>
                        <div class="input-wrapper">
                            <i class="bi bi-person-circle input-icon"></i>
                            <input type="text" class="form-control" name="username" placeholder="Enter your username or email" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label><i class="bi bi-lock"></i> Password</label>
                        <div class="input-wrapper">
                            <i class="bi bi-lock input-icon"></i>
                            <input type="password" class="form-control" id="loginPassword" name="password" placeholder="Enter your password" required>
                            <i class="bi bi-eye password-toggle" onclick="togglePassword('loginPassword', this)"></i>
                        </div>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" id="rememberMe">
                        <label for="rememberMe">Remember me</label>
                    </div>
                    <div class="forgot-password">
                        <a href="@Url.Action("ForgotPassword", "Account")" class="form-link">Forgot Password?</a>
                    </div>
                    <button type="submit" class="btn-primary-custom">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Login
                    </button>
                    <div class="divider">
                        <span>or continue with</span>
                    </div>
                    <div class="social-login">
                        <button type="button" class="social-btn" title="Login with Google">
                            <i class="bi bi-google"></i>
                        </button>
                        <button type="button" class="social-btn" title="Login with Facebook">
                            <i class="bi bi-facebook"></i>
                        </button>
                        <button type="button" class="social-btn" title="Login with Apple">
                            <i class="bi bi-apple"></i>
                        </button>
                    </div>
                    <div class="form-footer">
                        Don't have an account? <a href="@Url.Action("Register", "Account")" class="form-link">Sign up</a>
                    </div>
                </form>

                <div class="back-home">
                    <a href="@Url.Action("LandingPage", "Home")">
                        <i class="bi bi-arrow-left"></i> Back to Home
                    </a>
                </div>

            </div>
        </div>

        <!-- RIGHT: Image Side -->
        <div class="auth-image-side-login">
            <div class="auth-image-overlay">
                <div class="auth-image-content">
                    <h2>Discover Amazing Events from your Community</h2>
                    <p>Join thousands of people connecting and celebrating together in your community.</p>
                    <div class="auth-image-stats">
                        <div class="stat">
                            <span class="stat-number">500+</span>
                            <span class="stat-label">Events</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">10k+</span>
                            <span class="stat-label">Members</span>
                        </div>
                        <div class="stat">
                            <span class="stat-number">50+</span>
                            <span class="stat-label">Cities</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script src="~/Scripts/jquery-3.7.0.min.js"></script>
    <script src="~/Content/UserInterface/AccountAuth_Ajax.js"></script>
</body>
</html>