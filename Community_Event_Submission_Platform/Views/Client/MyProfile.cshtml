@{
    ViewBag.Title = "My Profile";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CommunityHub Events! - My Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/Content/client-home.css" rel="stylesheet">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="#">
                <i class="bi bi-calendar-event"></i> CommunityHub Events!
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">

                    <!-- Profile Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link profile-link dropdown-toggle d-flex align-items-center gap-2"
                           href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="bi bi-person-circle"></div>
                            Profile
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end custom-dropdown">
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="bi bi-person me-2"></i>My Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("Home", "Client")">
                                    <i class="bi bi-calendar-event me-2"></i>Dashboard
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="bi bi-gear me-2"></i>Settings
                                </a>
                            </li>
                        </ul>
                    </li>
                    <!-- Logout -->
                    <li class="nav-item">
                        <a class="nav-link logout-link d-flex align-items-center gap-1"
                           href="@Url.Action("Logout","Client")" id="logoutBtn">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Profile Page -->
    <section class="profile-wrapper">
        <div class="container py-5">
            <div class="row g-4">

                <!-- LEFT SIDEBAR -->
                <div class="col-lg-4">
                    <div class="card profile-sidebar shadow-sm border-0">

                        <div class="text-center p-4">
                            <div class="avatar-circle mb-3">
                                @(ViewBag.Username != null ? ViewBag.Username.ToString().Substring(0,1).ToUpper() : "U")
                            </div>

                            <h4 class="fw-bold mb-1">@ViewBag.Username</h4>
                            <p class="text-muted mb-3">@("@"+ViewBag.Username)</p>

                            <button class="btn btn-primary w-100 mb-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editModal">
                                Edit Profile
                            </button>

                            <div class="small text-muted mt-3">
                                <p class="mb-1"><i class="bi bi-geo-alt me-1"></i> @(ViewBag.Location ?? "Not set")</p>
                                <p><i class="bi bi-calendar3 me-1"></i> Member since @DateTime.Now.ToString("MMM yyyy")</p>
                            </div>
                        </div>

                        <div class="stats d-flex justify-content-around py-3 border-top">
                            <div class="text-center">
                                <h5 class="fw-bold mb-0">0</h5>
                                <small class="text-muted">Joined</small>
                            </div>
                            <div class="text-center">
                                <h5 class="fw-bold mb-0">0</h5>
                                <small class="text-muted">Hosted</small>
                            </div>
                            <div class="text-center">
                                <h5 class="fw-bold mb-0">0</h5>
                                <small class="text-muted">Followers</small>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- RIGHT CONTENT -->
                <div class="col-lg-8">

                    <!-- ABOUT -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body">
                            <h5 class="fw-bold mb-3">About Me</h5>
                            <p class="text-muted">
                                @(ViewBag.Bio ?? "No bio yet — tell the community about yourself!")
                            </p>
                        </div>
                    </div>

                    <!-- EVENTS -->
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="fw-bold mb-0">My Events</h5>
                                <a href="@Url.Action("MyEvent","Client")"
                                   class="btn btn-outline-primary btn-sm">
                                    + Create Event
                                </a>
                            </div>

                            <div class="row g-3">
                                @if(ViewBag.events != null && ((System.Data.DataTable)ViewBag.events).Rows.Count > 0) 
                                { 
                                    foreach(System.Data.DataRow item in ((System.Data.DataTable)ViewBag.events).Rows) 
                                    { 
                                        <div class="col-md-6">
                                            <div class="event-card-card p-3 rounded">
                                                <h6 class="fw-semiboldmb-1">@item["title"] </h6>
                                                <small class="text-muted">
                                                    <i class="bi bi-calendar-event me-1"></i>
                                                    @Convert.ToDateTime(item["event_datetime"]).ToString("MMM dd, yyyy")
                                                </small>
                                            </div>
                                        </div>


                                        <div class="event-tumb">
                                            <div class="event=tumb-img">
                                                @if (!string.IsNullOrEmpty(item["image_url"]?.ToString()))
                                                {
                                                    <img src="@Url.Content("~/Utilities/" + item["image_url"])"
                                                         alt="@item["title"]"
                                                         style="width:100%; height:100%; object-fit:cover; border-radius:8px;" />
                                                }
                                                else
                                                {
                                                    <i class="bi bi-calendar-event"></i>
                                                }

                                            </div>
                                        </div>
                                        
                                        <div class="event-thumb-body">
                                            <p>@item["title"]</p>
                                            <span>
                                                @{
                                                    var eventDate = Convert.ToDateTime(item["event_datetime"]);
                                                    var eventTime = item["event_time"]?.ToString();
                                                }
                                                @eventDate.ToString("MMM dd, yyyy") at @eventTime

                                            </span>
                                        </div>

                                    }
                                    
                                }
                                else
                                {
                                    <div class="col-12 text-center py-4 text-muted">
                                        No events yet. Start by creating one!
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </section>

    <!-- Edit Profile Modal -->
    <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel">
                        <i class="bi bi-pencil-square me-2" style="color:var(--primary-color);"></i>Edit Profile
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="editProfileForm">
                        <div class="mb-3">
                            <label class="form-label">Display Name</label>
                            <input type="text" class="form-control" id="inputName"
                                   placeholder="Your name" value="@ViewBag.Username">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Location</label>
                            <input type="text" class="form-control" id="inputLocation"
                                   placeholder="e.g. New York, USA" value="@ViewBag.Location">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Bio</label>
                            <textarea class="form-control" id="inputBio" rows="3"
                                      placeholder="Tell the community about yourself...">@ViewBag.Bio</textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-save" id="saveProfileBtn">
                        <i class="bi bi-check2 me-1"></i> Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/client-home.js"></script>
</body>
</html>
