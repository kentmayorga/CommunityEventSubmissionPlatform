
@{
    ViewBag.Title = "Create Community";
}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">🏘️ Create Community</h4>
                </div>
                <div class="card-body">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            <i class="fa fa-check-circle"></i> @TempData["Success"]
                            <button type="button" class="close" data-dismiss="alert">&times;</button>
                        </div>
                    }

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="fa fa-exclamation-circle"></i> @ViewBag.Message
                            <button type="button" class="close" data-dismiss="alert">&times;</button>
                        </div>
                    }

                    @using (Html.BeginForm("Create", "Community", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        @* Community Name *@
                        <div class="form-group">
                            <label for="name">Community Name <span class="text-danger">*</span></label>
                            @Html.TextBox("name", null, new
                            {
                                @class = "form-control",
                                placeholder = "Enter community name",
                                id = "name"
                            })
                        </div>

                        @* Description *@
                        <div class="form-group">
                            <label for="description">Description <span class="text-danger">*</span></label>
                            @Html.TextArea("description", null, 4, 0, new
                            {
                                @class = "form-control",
                                placeholder = "Describe the community...",
                                id = "description"
                            })
                        </div>

                        @* Privacy *@
                        <div class="form-group">
                            <label for="privacy">Privacy</label>
                            @Html.DropDownList("privacy",
                                new SelectList(new[]
                                {
                                    new { Value = "public",  Text = "🌐 Public — Anyone can see" },
                                    new { Value = "private", Text = "🔒 Private — Invite only" }
                                }, "Value", "Text"),
                                new { @class = "form-control", id = "privacy" }
                            )
                        </div>

                        @* Invite Code *@
                        <div class="form-group">
                            <label for="invite_code">Invite Code <span class="text-danger">*</span></label>
                            <div class="input-group">
                                @Html.TextBox("invite_code", null, new
                                {
                                    @class = "form-control",
                                    placeholder = "e.g. COMM-2024",
                                    id = "invite_code"
                                })
                                <div class="input-group-append">
                                    <button type="button" class="btn btn-outline-secondary" onclick="generateCode()">
                                        <i class="fa fa-refresh"></i> Generate
                                    </button>
                                </div>
                            </div>
                            <small class="text-muted">Members will use this code to join the community.</small>
                        </div>

                        @* Date Created (read-only, auto-set) *@
                        <div class="form-group">
                            <label for="created_date">Date Created</label>
                            <input type="text"
                                   id="created_date"
                                   class="form-control"
                                   readonly
                                   style="background-color:#f8f9fa; cursor:not-allowed;" />
                            <small class="text-muted">Automatically set to today's date.</small>
                        </div>

                        <hr />


                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary">
                                <i class="fa fa-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-plus"></i> Create Community
                            </button>
                        </div>
                    }

                </div>

            </div>

        </div>

    </div>
</div>


@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        window.onload = function () {
            // Auto-set today's date display
            var now = new Date();
            var options = { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
            document.getElementById('created_date').value = now.toLocaleDateString('en-US', options);

            // Auto-generate invite code
            generateCode();
        };

        function generateCode() {
            var chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
            var code = 'COMM-';
            for (var i = 0; i < 6; i++) {
                code += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            document.getElementById('invite_code').value = code;
        }
    </script>
}
